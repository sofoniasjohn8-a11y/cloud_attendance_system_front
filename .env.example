# Attendance System Frontend - Environment Variables

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:8000/api

# Application Name
VITE_APP_NAME=Cloud Attendance System

# Office Location Configuration
# Update these with your actual office coordinates
VITE_OFFICE_LATITUDE=40.7128
VITE_OFFICE_LONGITUDE=-74.0060

# Geofence Radius in meters
VITE_GEOFENCE_RADIUS=100

# Debug Mode (set to false in production)
VITE_DEBUG_MODE=true
